        <mxCell id="ee4_3" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="ex4_3" target="ex4_4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ex5_title" value="场景 ⑤  极端帧：无星、无敌可见、所有策略均失败" style="text;html=1;strokeColor=none;fillColor=#f5f5f5;align=left;fontStyle=1;fontSize=12;rounded=1;strokeColor=#666;" parent="1" vertex="1">
          <mxGeometry x="30" y="470" width="540" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ex5_flow" value="Root→①FAIL→②FAIL→③FAIL→④FAIL→⑤⑥⑦FAIL→⑧FAIL→⑨FAIL→⑩FAIL →⑪ movement Selector:    ambush-shift/confirm/hold → 无ambushState，FAIL    bush-hold → 非overload敌 or 不在草丛，FAIL    short-intent → 无缓存意图，FAIL    star-chase → !bb.star, FAIL    band-escape → 无overload威胁，FAIL    occupy-lane → 无敌可见，FAIL    maintain-standoff → 无敌可见，FAIL    cloak-defense → 无cloak记录，FAIL    escape-ambush → 无最近敌位，FAIL    patrol → virtualPatrolTarget()找到目标格，SUCCESS!    → bbMoveToward(patrolStep) 巡逻移动" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="30" y="510" width="540" height="195" as="geometry" />
        </mxCell>
        <mxCell id="ex5_note" value="兜底保底：patrol失败→dig→safe-neighbor→turn-right，100%有输出，不会挂机" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="30" y="710" width="540" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ex6_title" value="场景 ⑥  护盾流 (shield)：敌盾激活中，距离≤3，有射线" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;fontStyle=1;fontSize=12;rounded=1;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="600" y="395" width="540" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ex6_1" value="Profile: shield shieldBait=true attackAgg=cautious" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="600" y="435" width="130" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ex6_2" value="①~④ 全FAIL" style="rounded=1;fillColor=#f5f5f5;strokeColor=#ccc;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="745" y="435" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ex6_3" value="⑧ attack Selector: open-shot→FAIL(有盾) shield-preaim Seq:   enemy-shielded→TRUE   has-clear-shot→TRUE   close-range(≤3)→TRUE ✅ 转向对准(不开火) 等待下帧盾消失" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="860" y="420" width="165" height="115" as="geometry" />
        </mxCell>
        <mxCell id="ex6_4" value="下一帧：盾消失 → fire-direct:   safe-to-fire=TRUE ✅ bbFire() 直射!" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1045" y="435" width="130" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ee6_1" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="ex6_1" target="ex6_2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ee6_2" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="ex6_2" target="ex6_3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ee6_3" value="盾消失" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="ex6_3" target="ex6_4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ex7_title" value="场景 ⑦  传送伏击完整流程：有星，传送就绪，附近有草丛" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=left;fontStyle=1;fontSize=12;rounded=1;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="600" y="555" width="560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ex7_1" value="帧N: objective→ star-bush-ambush Seq star-exists→TRUE tp-ready→TRUE enemy-allows→TRUE has-ambush-pos→TRUE ✅ bbTeleport(草丛格) 记录 ambushState" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="600" y="595" width="150" height="115" as="geometry" />
        </mxCell>
        <mxCell id="ex7_2" value="帧N+1: movement→ ambush-shift Seq needs-shift=TRUE(刚传) shift-safe=TRUE ✅ 移到相邻草丛格" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="765" y="595" width="150" height="85" as="geometry" />
        </mxCell>
        <mxCell id="ex7_3" value="帧N+2: movement→ ambush-shift-confirm → 到达shiftTarget → shifted=true" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="930" y="595" width="150" height="75" as="geometry" />
        </mxCell>
        <mxCell id="ex7_4" value="帧N+3..M: movement→ ambush-hold Seq in-ambush=TRUE 敌进入射线时: ✅ bbFire() 说：伏击!" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1095" y="595" width="150" height="85" as="geometry" />
