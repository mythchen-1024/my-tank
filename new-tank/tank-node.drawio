        </mxCell>
        <mxCell id="ex4_title" value="场景 ④  双弹流敌人 (overload)：我在草丛，敌进射线" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=left;fontStyle=1;fontSize=12;rounded=1;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="600" y="225" width="540" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ex4_1" value="Profile: overload attackAgg=low bushCamp=true dodgeBand=true" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="600" y="265" width="130" height="65" as="geometry" />
        </mxCell>
        <mxCell id="ex4_2" value="①~④ 全FAIL (无子弹/无瞄准) ⑤~⑦ When条件不满足" style="rounded=1;fillColor=#f5f5f5;strokeColor=#ccc;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="745" y="265" width="140" height="65" as="geometry" />
        </mxCell>
        <mxCell id="ex4_3" value="⑧ attack(low) open-shot→无空窗FAIL (其余均未挂载) → FAIL整个attack" style="rounded=1;fillColor=#f5f5f5;strokeColor=#ccc;fontSize=9;" parent="1" vertex="1">
