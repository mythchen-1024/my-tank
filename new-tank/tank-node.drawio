  <diagram id="9xorrafy-pvi3" name="黑板感知系统">
    <mxGraphModel dx="953" dy="481" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Blackboard 黑板感知系统 — 每帧刷新流程" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;spacingLeft=4;fontStyle=1;fontSize=16;" parent="1" vertex="1">
          <mxGeometry x="300" y="10" width="700" height="35" as="geometry" />
        </mxCell>
        <mxCell id="rb" value="refreshBlackboard(bb, me, enemy, game)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="350" y="60" width="350" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="① 原始数据绑定 (O(1)每帧必做)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="100" y="145" width="250" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s1d" value="&lt;div&gt;bb.me / bb.enemy / bb.game&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.myPos = me.tank.position&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.myDir = me.tank.direction&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.enemyTank / bb.enemyPos&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.enemyBullets = collectEnemyBullets()&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.star = game.star&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.bombs = game.bombs&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffc0;strokeColor=#d6b656;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="100" y="185" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="② 廉价派生感知 (O(1)每帧必算)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="390" y="145" width="270" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s2d" value="&lt;div&gt;bb.gunIsReady = gunReady(me)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.teleportIsReady = teleportReady(me)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.bombIsReady = bombReady(me)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.shotDir = clearShotDirection(myPos, enemyPos)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.distToEnemy = manhattan(myPos, enemyPos)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.distToStar = manhattan(myPos, star)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.framesLeft = MAX_FRAMES - frame&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.myStars / bb.enmStars&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb.isLosing / bb.isWinning / bb.isTied&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5f0d5;strokeColor=#82b366;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="390" y="185" width="270" height="145" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="③ 跨帧记忆更新 (state-store)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="700" y="145" width="250" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s3d" value="&lt;div&gt;bb.memory = getMatchState(game)&amp;nbsp;&lt;/div&gt;&lt;div&gt;recordAssassinOutcome() 刺杀结果记录&amp;nbsp;&lt;/div&gt;&lt;div&gt;trackEnemy() 记录敌人最后已知位置&amp;nbsp;&lt;/div&gt;&lt;div&gt;trackStuck() 检测卡死帧数&amp;nbsp;&lt;/div&gt;&lt;div&gt;cleanExpiredBombs() 清过期炸弹&amp;nbsp;&lt;/div&gt;&lt;div&gt;updatePhantomBullets() 幽灵弹补偿推算&amp;nbsp;&lt;/div&gt;&lt;div&gt;合并 myBombs → bombs 列表&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc0c0;strokeColor=#b85450;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="700" y="185" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="④ 清空惰性缓存 _cache={}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="990" y="145" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s4d" value="&lt;div&gt;bb._cache = {} (每帧重建)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb._trace = [] (调试追踪)&amp;nbsp;&lt;/div&gt;&lt;div&gt;bb._lastAction = null&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8d5f0;strokeColor=#9673a6;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="990" y="185" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="erb" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="rb" target="s1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="erb2" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="rb" target="s2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="erb3" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="rb" target="s3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="erb4" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="rb" target="s4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lazy_title" value="惰性传感器 sense(bb, key, fn)  — 首次访问时计算，本帧内复用" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="30" y="350" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ls_title" value="生存传感器" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="30" y="390" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ls_d" value="&lt;div&gt;senseBulletDodge() → findBulletDodge() ↳ 预判弹道，找相邻安全格&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseCounterShoot() → shouldCounterShootThenDodge() ↳ 反击后还能躲开？&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseEscapeTeleport() → findEscapeTeleport() ↳ 常规无法躲时找传送落点&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseTwoStepEscape() → findTwoStepEscape() ↳ 双弹夹击的两步脱困路径&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseDesperateDodge() → findDesperateDodge() ↳ 绝境时垂直弹道方向横移&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseBombThreat() → findBombDodge() ↳ 炸弹爆炸范围内逃离方向&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc0c0;strokeColor=#b85450;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="30" y="425" width="280" height="185" as="geometry" />
        </mxCell>
        <mxCell id="ss_title" value="软生存传感器" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="325" y="390" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ss_d" value="&lt;div&gt;senseOverloadLaneDodge() → findOverloadLaneDodge() ↳ 双弹覆盖带提前脱离格&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseAimDodge() → findAimDodge() ↳ 敌炮口已瞄准我，预判侧移&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseLineDuelDodge() → findLineDuelDodge() ↳ 近距同线时我不占先手，侧移离线&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseBushCamperDodge() → findBushCamperDodge() ↳ 高概率草丛炮线回避&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8d5f0;strokeColor=#9673a6;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="325" y="425" width="300" height="115" as="geometry" />
        </mxCell>
        <mxCell id="as_title" value="攻击传感器" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="640" y="390" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="as_d" value="&lt;div&gt;senseOpenShot() → findEnemyBulletOpenShot() ↳ 敌弹刚射出(炮管空)+我与敌同线&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseCloakPreFire() → findCloakPreFireShot() ↳ 隐身流刚消失时的预射方向&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseGuardLineShot() → findGuardLineShot() ↳ 预判敌/星将经过的路线守线&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseBushLineShot() → findBushLineShot() ↳ 草丛内伏击射线&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseBushPreFire() → findBushPreFireTarget() ↳ 草丛陷阱预射目标&amp;nbsp;&lt;/div&gt;&lt;div&gt;senseBlindBushShot() → findBlindBushShot() ↳ 敌消失后草丛盲射目标&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5f0d5;strokeColor=#82b366;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="640" y="425" width="310" height="185" as="geometry" />
