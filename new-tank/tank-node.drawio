        </mxCell>
        <mxCell id="obs_title" value="打法风格观察 (memory._profiler)" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="30" y="57.5" width="260" height="35" as="geometry" />
        </mxCell>
        <mxCell id="obs_d" value="enemyVisibleFrames    敌人可见总帧数&amp;nbsp;&lt;div&gt;enemyFacingMeFrames   敌人朝向我帧数&amp;nbsp;&lt;/div&gt;&lt;div&gt;enemyFleeingFrames    逃跑帧数&amp;nbsp;&lt;/div&gt;&lt;div&gt;enemyStarRushCount    新星刷新立刻冲次数&lt;/div&gt;&lt;div&gt;bushCamperStats       草丛行为统计(传送/走入/开火)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;多特征标志检测(可叠加,互斥:aggr/def):&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;facingRatio &amp;gt; 40% &amp;amp;&amp;amp; ≥ fleeRatio → isAggressive&amp;nbsp;&lt;/div&gt;&lt;div&gt;fleeRatio  &amp;gt; 35% &amp;amp;&amp;amp; &amp;gt; facingRatio → isDefensive&amp;nbsp;&lt;/div&gt;&lt;div&gt;starRush ≥ 2次                    → isStarRusher&amp;nbsp;&lt;/div&gt;&lt;div&gt;传送进草/走进草2次/草丛开火2次   → isBushCamper&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;即时路径:&lt;/b&gt; 传送进草帧 → 立刻激活 isBushCamper&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;滞后保持:&lt;/b&gt; TRAIT_HOLD_FRAMES=32帧防振荡&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffc0c0;strokeColor=#b85450;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="30" y="107.5" width="310" height="240" as="geometry" />
        </mxCell>
        <mxCell id="eobs" style="edgeStyle=orthogonalEdgeStyle;" parent="1" source="obs_title" target="entry" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fix_title" value="动态打法修正" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="700" y="55" width="160" height="35" as="geometry" />
        </mxCell>
        <mxCell id="fix_d" value="&lt;b&gt;各 trait 独立叠加修正(顺序执行):&lt;/b&gt;&amp;nbsp;&lt;div&gt;isAggressive → standoff=max(x,5), 攻击降级(high→med)&amp;nbsp;&lt;/div&gt;&lt;div&gt;isDefensive  → standoff=min(x,3), starAggr=max&amp;nbsp;&lt;/div&gt;&lt;div&gt;isStarRusher → starAggr=max&amp;nbsp;&lt;/div&gt;&lt;div&gt;isBushCamper → starAggr≥high, atk升级(low→med),&amp;nbsp;&lt;/div&gt;&lt;div&gt;              bushCamperDefense=true, standoff=min(x,4)&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;maintain-standoff消费:&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;实际距离 = max(profile.standoff, safeStandoff(enemy))&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;终局修正(覆盖所有trait):&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;framesLeft≤20 &amp;amp;&amp;amp; isLosing → starAgg=max, atk=low&amp;nbsp;&lt;/div&gt;&lt;div&gt;framesLeft≤10            → starAgg=max, atk=none&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;即时重建触发(entry.js):&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;传送进草当帧 → needRebuild=true → 立即切bushCamperDefense&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8d5f0;strokeColor=#9673a6;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="870" y="50" width="345" height="240" as="geometry" />
        </mxCell>
