        </mxCell>
        <mxCell id="ex4_4" value="⑪ movement → ambush-hold Seq    in-ambush=TRUE(蹲草中)    still-safe=TRUE(无弹)    shotDir存在→ 敌入射线! ✅ bbFire() 说：伏击!" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1045" y="250" width="145" height="95" as="geometry" />
        </mxCell>
        <mxCell id="ex4_note" value="注：伏击开火在 movement 层执行，不受 attackAggression=low 限制，这是蹲草流的关键设计" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontStyle=2;" parent="1" vertex="1">
          <mxGeometry x="600" y="360" width="630" height="20" as="geometry" />
