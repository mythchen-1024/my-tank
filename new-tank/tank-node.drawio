        <mxCell id="impact_title" value="Profile 参数 → 子树挂载控制" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="770" y="360" width="330" height="30" as="geometry" />
        </mxCell>
        <mxCell id="impact_d" value="attackAggression 值   → 攻击节点挂载范围:&amp;nbsp;&lt;div&gt;none     仅frozen/survival/objective/movement&amp;nbsp;&lt;/div&gt;&lt;div&gt;low      + open-shot&amp;nbsp;&lt;/div&gt;&lt;div&gt;cautious + shield-preaim + fire-direct/risky&amp;nbsp;&lt;/div&gt;&lt;div&gt;medium   + guard-line&amp;nbsp;&lt;/div&gt;&lt;div&gt;high     + cloak-prefire + bush-shot&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;dodgeBand=true         → 挂载 overload-lane-dodge&amp;nbsp;&lt;/div&gt;&lt;div&gt;freezeZoneAvoid=true   → 挂载 freeze-zone-avoid&amp;nbsp;&lt;/div&gt;&lt;div&gt;prefireOnDisappear=true → 挂载 cloak-prefire&amp;nbsp;&lt;/div&gt;&lt;div&gt;shieldBait=true        → 挂载 shield-preaim&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;bushCamperDefense=true → 挂载 bush-camper-dodge(软生存)&lt;/b&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;bushCamp=true          → 挂载 bush-hold + seek-bush&amp;nbsp;&lt;/div&gt;&lt;div&gt;                         屏蔽 occupy-lane&amp;nbsp;&lt;/div&gt;&lt;div&gt;enableAssassination=true → 挂载 assassination&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;starAggression 值      → objective 层行为:&amp;nbsp;&lt;/div&gt;&lt;div&gt;  low  → 敌近星时不传送&amp;nbsp;&lt;/div&gt;&lt;div&gt;  high → 正常传送抢星&amp;nbsp;&lt;/div&gt;&lt;div&gt;  max  → 目标层提权到攻击前&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="770" y="390" width="360" height="340" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
